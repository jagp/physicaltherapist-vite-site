;; vite-react-ssg@0.9.1-beta.1 declares peer vite@^2-^7 but we run Vite 8.
;; The combination is build-verified; without this flag CI's `npm ci`
;; hard-fails on ERESOLVE (this is what broke the Cloudflare Pages build).
;; Remove once vite-react-ssg publishes a Vite 8 peer range.
legacy-peer-deps=true
