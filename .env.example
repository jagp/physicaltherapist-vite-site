# Copy to .env.local (gitignored) for local dev. Real values never live here:
# put yours in .env.local, or in the Cloudflare Pages dashboard (Settings >
# Environment variables > Production) for the live site. All VITE_* vars are
# inlined into the client bundle at build time — restart the dev server after
# changing them.

# --- Contact form (EmailJS) -------------------------------------------------
# From the EmailJS dashboard (https://dashboard.emailjs.com). All three are
# required for the form to send. The public key is safe to expose client-side;
# the recipient address is configured in the EmailJS template, not in code.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# --- Analytics (Google Tag Manager) ------------------------------------------
# When set to a valid GTM-XXXXXXX, GTM is injected into every pre-rendered page
# at build time (see gtmPlugin in vite.config.ts). Leave blank to disable GTM —
# this is the default for local dev. Never commit a real ID.
VITE_GTM_ID=
