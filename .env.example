# Google Tag Manager container ID.
# When set to a valid GTM-XXXXXXX, GTM is injected into every pre-rendered page
# at build time (see gtmPlugin in vite.config.ts). Leave blank to disable GTM —
# this is the default for local dev.
#
# Real values never live here: put yours in .env.local (gitignored) for local
# testing, or in the Cloudflare Pages dashboard (Settings > Environment variables
# > Production) for the live site. Never commit a real ID.
VITE_GTM_ID=
